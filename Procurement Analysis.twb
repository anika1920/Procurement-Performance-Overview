      <column caption='Lead Time Bucket' datatype='string' name='[Calculation_1290280962097155]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Lead_Time_Days] &lt;= 5 THEN &quot;0-5&quot;&#13;&#10;ELSEIF [Lead_Time_Days] &lt;= 8 THEN &quot;6-8&quot;&#13;&#10;ELSEIF [Lead_Time_Days] &lt;= 10 THEN &quot;9-10&quot;&#13;&#10;ELSEIF [Lead_Time_Days] &lt;= 12 THEN &quot;11-12&quot;&#13;&#10;ELSEIF [Lead_Time_Days] &lt;= 15 THEN &quot;13-15&quot;&#13;&#10;ELSE &quot;16+&quot; END' />
