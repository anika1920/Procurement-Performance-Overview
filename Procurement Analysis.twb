      <column caption='OTD_Rate' datatype='real' default-format='p0.00%' name='[Calculation_0982416613523456]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([OTD_Flag]) / COUNT([PO_ID])' />
      </column>
      <column caption='Defect_Rate' datatype='real' default-format='p0.00%' name='[Calculation_0982416614002690]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Defective_Units]) / SUM([Quantity])' />
      </column>
      <column caption='Compliance_Rate' datatype='real' name='[Calculation_0982416614150147]' role='measure' type='quantitative'>
