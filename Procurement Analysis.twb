      </column>
      <column caption='Threshold_Color (OTD)' datatype='string' name='[Calculation_0982416614285316]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0982416613523456] &gt;= [Parameters].[OTD Flag Parameter] THEN &quot;Safe&quot; ELSEIF [Calculation_0982416613523456] &gt;= 0.80 THEN &quot;Watch&quot; ELSE &quot;Risk&quot; END' />
      </column>
      <column caption='Threshold_Color (Defect)' datatype='string' name='[Calculation_0982416615890950]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0982416614002690] &lt;= [Parameters].[Defect Threshold % Parameter] THEN &quot;Safe&quot; ELSEIF [Calculation_0982416614002690] &lt;= 0.025 THEN &quot;Watch&quot; ELSE &quot;Risk&quot; END' />
      </column>
      <column caption='Spend_12mo_RollingAvg' datatype='real' name='[Calculation_0982416616419335]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG(SUM([Total_Spend]), -11, 0)'>
