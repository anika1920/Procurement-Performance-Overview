      <column caption='Budget- indicidual' datatype='real' name='[Calculation_0503581145477120]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Budget])/COUNT([PO_ID])' />
      </column>
      <column caption='Fixed budget' datatype='integer' name='[Calculation_0503581159596034]' role='measure' type='quantitative'>
