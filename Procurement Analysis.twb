    <dashboard name='Story 1' type='storyboard'>
      <style>
        <style-rule element='story-point-caption'>
          <format attr='width' value='572' />
        </style-rule>
      </style>
      <size maxheight='850' maxwidth='1100' minheight='850' minwidth='1100' preset-index='11' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98118' id='1' param='vert' removable='false' type-v2='layout-flow' w='98546' x='727' y='941'>
            <zone h='4353' id='3' type-v2='title' w='98546' x='727' y='941' />
            <zone h='11882' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98546' x='727' y='5294' />
            <zone h='81883' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98546' x='727' y='17176'>
              <flipboard active-id='5' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='The Procurement Scoreboard at a Glance: 707 orders worth 46.3M delivered across FY2022–FY2024, with 3.99M in cost savings achieved — but only 48.67% of orders arrive on time and 5.58% of units are defective, signalling that cost is managed while reliability and quality are not.' captured-sheet='Dashboard 1 ' id='1' />
                  <story-point caption='A Predictable Seasonal Rhythm with No Growth Underneath: spend peaks in March at 5.34M (44% above the rolling average) and bottoms in May at 2.69M, but the flat 12-month rolling average at ~3.7M confirms procurement is cycling the same volume year after year — efficiency, not scale, is the only available lever for improvement.' captured-sheet='Sheet 5' id='6' />
                  <story-point caption='The Real Reason OTD Sits at 49%: the mode of 6–8 days (200 orders) looks healthy, but a structural long tail of 177 orders — fully 25% of total volume — falls into the 16+ day risk zone, meaning one in every four orders consistently breaches the 15-day delivery threshold and this is what is pulling the entire OTD average down.' captured-sheet='Sheet 8' id='2'>
                    <capturedDeltas>
                      <worksheet name='Sheet 8'>
                        <annotations>
                          <annotation class='point' delta-type='added' id='0' mark-position='1' pullback='12' text-width='180'>
                            <formatted-text>
                              <run bold='true' fontalignment='0'>531 orders take 16+ days — our biggest delivery problem.</run>
                            </formatted-text>
                            <point>
                              <visual-coordinate class='mark'>
                                <tuple-reference>
                                  <tuple-descriptor>
                                    <pane-descriptor>
                                      <x-fields>
                                        <field>[federated.1jhp7oa0ofrbhz1gift5g0305rtj].[none:Calculation_1290280962097155:nk]</field>
                                      </x-fields>
                                      <y-fields>
                                        <field>[federated.1jhp7oa0ofrbhz1gift5g0305rtj].[cnt:PO_ID:qk]</field>
                                      </y-fields>
                                    </pane-descriptor>
                                    <columns>
                                      <field>[federated.1jhp7oa0ofrbhz1gift5g0305rtj].[cnt:PO_ID:qk]</field>
                                      <field>[federated.1jhp7oa0ofrbhz1gift5g0305rtj].[none:Calculation_1290280962097155:nk]</field>
                                    </columns>
                                  </tuple-descriptor>
                                  <tuple>
                                    <value>531</value>
                                    <value>&quot;16+&quot;</value>
                                  </tuple>
                                </tuple-reference>
                              </visual-coordinate>
                            </point>
                            <body x='130' y='-20' />
                          </annotation>
                        </annotations>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Lead Time Is Suspiciously Uniform Across the Supplier Panel — A Systemic Problem, Not a Supplier Problem: Alpha 9.94, Gamma 9.88, Delta 10.36, Epsilon 10.42, Beta 10.87 days — a range of under one day across all five suppliers tells us the bottleneck is internal (customs, warehouse, PO release) rather than supplier capability, so the fix must be process redesign, not supplier replacement.' captured-sheet='Dashboard 2' id='7' />
                  <story-point caption='Quality Risk Is Concentrated, Not Spread: Delta Logistics Owns 4 of the 5 Worst Cells — while Alpha and Epsilon stay safely below 3% across every category, Delta produces 13.77% defects on Office Supplies (2.75x the safe threshold), 11.15% on Raw Materials, and 10.90% on MRO, making this single supplier the source of nearly all critical-zone quality outcomes in the portfolio.' captured-sheet='Sheet 11' id='3'>
                    <capturedDeltas>
                      <worksheet name='Sheet 11'>
                        <annotations>
                          <annotation class='point' delta-type='added' id='0' mark-position='1' pullback='12' text-width='180'>
                            <formatted-text>
                              <run bold='true' fontalignment='0'>13.77% defect rate — 2.7x the safe threshold of 5%.</run>
                            </formatted-text>
                            <point>
                              <visual-coordinate class='mark'>
                                <tuple-reference>
                                  <tuple-descriptor>
                                    <pane-descriptor>
                                      <x-fields>
                                        <field>[federated.1jhp7oa0ofrbhz1gift5g0305rtj].[none:Supplier:nk]</field>
                                      </x-fields>
                                      <y-fields>
                                        <field>[federated.1jhp7oa0ofrbhz1gift5g0305rtj].[none:Item_Category:nk]</field>
                                      </y-fields>
                                    </pane-descriptor>
                                    <columns>
                                      <field>[federated.1jhp7oa0ofrbhz1gift5g0305rtj].[cnt:PO_ID:qk]</field>
                                      <field>[federated.1jhp7oa0ofrbhz1gift5g0305rtj].[none:Item_Category:nk]</field>
                                      <field>[federated.1jhp7oa0ofrbhz1gift5g0305rtj].[none:Supplier:nk]</field>
                                      <field>[federated.1jhp7oa0ofrbhz1gift5g0305rtj].[usr:Calculation_0982416614002690:qk]</field>
                                    </columns>
                                  </tuple-descriptor>
                                  <tuple>
                                    <value>111</value>
                                    <value>&quot;Office Supplies&quot;</value>
                                    <value>&quot;Delta Logistics&quot;</value>
                                    <value>0.13771018995448722</value>
                                  </tuple>
                                </tuple-reference>
                              </visual-coordinate>
                            </point>
                            <body x='130' y='-20' />
                          </annotation>
                        </annotations>
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='The SLA Framework Is Masking the Real Performance Gap: every category clears its contracted SLA on paper (Electronics 10.5 vs Risk 19, MRO 10.5 vs Risk 21, Packaging 10.1 vs Risk 14), yet our overall OTD is still only 48.67% — meaning the SLA thresholds were set so generously that they hide operational problems, and they need to be tightened before they can serve as a real management tool.' captured-sheet='Sheet 17' id='8' />
                  <story-point caption='Three Consecutive Years of Budget Erosion: FY2022 ended 1.54M under budget (6.7% favourable), FY2023 shifted to 1.49M over budget (6.7% unfavourable), and FY2024 (partial-year) is already 928K over budget, indicating a continuing decline in budget control driven by operational inefficiencies.' captured-sheet='Sheet 15' id='4' />
                  <story-point caption='From Diagnosis to Decision — Three Actions to Reverse the Performance Slide in Q1 FY2025: renegotiate or replace Delta Logistics within 60 days for Office Supplies and Raw Materials; redesign the internal lead time process within 90 days since supplier panel uniformity proves the bottleneck is internal; reinstate monthly budget variance reviews immediately with this dashboard as the single source of truth — moving procurement from reactive firefighting to proactive performance management.' captured-sheet='' id='5' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='78235' id='6' story-point-id='5' type-v2='text' w='97636' x='727' y='17176'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Calibri' fontsize='16'>Recommendations :</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Calibri'>1. RENEGOTIATE OR REPLACE DELTA LOGISTICS (60-day action)</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Calibri'>Delta drives 4 of 5 critical defect cells. Pursue dual-source qualification for Office Supplies and Raw Materials.</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Calibri'>Expected impact:</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Calibri'> defect rate from </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Calibri'>5.58% toward 3%</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Calibri'>.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Calibri'>2. REDESIGN THE LEAD TIME PROCESS, NOT THE SUPPLIER PANEL (90-day action)</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Calibri'>All 5 suppliers cluster within 1 day of each other — the bottleneck is internal. Audit customs clearance, warehouse receiving, and PO release timing.</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Calibri'>Expected impact:</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Calibri'> OTD from </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Calibri'>48.67% toward 70% by end of FY2025</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Calibri'>.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Calibri'>3. REINSTATE BUDGET DISCIPLINE NOW (immediate action)</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Calibri'>Three-year trend is deteriorating. Introduce monthly variance reviews using this dashboard as the source of truth. Tie supplier renewal decisions to budget compliance.</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Calibri'>Expected impact:</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Calibri'> improved budget control and reduced overspend risk.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Calibri'>4. IMPLEMENT SUPPLIER PERFORMANCE SCORECARD &amp; QUALITY CONTROL (60–90 day action)</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Calibri'>Beta Supplies and Delta Logistics show the highest defect rates and weaker compliance performance. Introduce monthly supplier KPI reviews covering OTD, defect rate, SLA compliance, and budget impact, with corrective action plans for underperforming suppliers.</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Calibri'>Expected impact:</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Calibri'> defect rate from </run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Calibri'>5.58% toward 3–4%</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Calibri'> and improved supplier accountability.</run>
            <run fontalignment='0'>Æ&#10;</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{E694B013-54B2-420F-9A87-F88FF3A65BB2}' />
    </dashboard>
  </dashboards>
  <windows saved-dpi-scale-factor='1.25' source-height='37'>
    <window class='worksheet' name='Sheet 1'>
      <cards>
        <edge name='left'>
          <strip size='160'>
